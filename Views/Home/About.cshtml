@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_WebLayout.cshtml";
}

<style>
    .about-hero {
        padding: 60px 0 40px 0;
        text-align: center;
    }

    .about-hero h1 {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: #2d3748;
    }

    .about-hero p {
        font-size: 1.2rem;
        color: #718096;
    }

    .about-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        margin-bottom: 3rem;
        transition: transform 0.3s ease;
    }

    .about-card:hover {
        transform: translateY(-5px);
    }

    .about-card-img {
        width: 100%;
        height: 400px;
        object-fit: cover;
    }

    .about-card-content {
        padding: 2.5rem;
    }

    .about-label {
        text-transform: uppercase;
        font-size: 0.85rem;
        font-weight: 600;
        color: #667eea;
        margin-bottom: 0.5rem;
        letter-spacing: 1px;
    }

    .about-card h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: #2d3748;
    }

    .about-card p {
        color: #4a5568;
        line-height: 1.8;
        font-size: 1.05rem;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-bottom: 4rem;
    }

    .feature-item {
        text-align: center;
        padding: 2rem;
        background: #f7fafc;
        border-radius: 15px;
        transition: all 0.3s ease;
    }

    .feature-item:hover {
        background: white;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        transform: translateY(-3px);
    }

    .feature-icon {
        font-size: 3rem;
        color: #667eea;
        margin-bottom: 1rem;
    }

    .feature-item h3 {
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #2d3748;
    }

    .feature-item p {
        color: #718096;
        font-size: 0.95rem;
    }

    @@media (max-width: 768px) {
        .about-hero h1 {
            font-size: 2rem;
        }
        
        .about-card-img {
            height: 250px;
        }
        
        .about-card-content {
            padding: 1.5rem;
        }
        
        .feature-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- Hero Section -->
<div class="about-hero">
    <div class="container-fluid" style="width: 90%; max-width: 1600px; margin: 0 auto;">
        <h1 class="poetsen-font">About ReSole</h1>
        <p>Discover the story behind your next favorite pair</p>
    </div>
</div>

<!-- Main Content -->
<div class="container-fluid" style="width: 90%; max-width: 1600px; margin: 0 auto;">
    <!-- Features Grid - Moved to top -->
    <div class="feature-grid">
        <div class="feature-item">
            <div class="feature-icon">
                <i class="bi bi-stars"></i>
            </div>
            <h3 class="poetsen-font">Premium Quality</h3>
            <p>Shoes curated from reputable brands and manufacturers</p>
        </div>

        <div class="feature-item">
            <div class="feature-icon">
                <i class="bi bi-heart"></i>
            </div>
            <h3 class="poetsen-font">Customer Care</h3>
            <p>Dedicated support to help you find the perfect fit</p>
        </div>

        <div class="feature-item">
            <div class="feature-icon">
                <i class="bi bi-truck"></i>
            </div>
            <h3 class="poetsen-font">Fast Delivery</h3>
            <p>Quick and reliable shipping right to your door</p>
        </div>

        <div class="feature-item">
            <div class="feature-icon">
                <i class="bi bi-arrow-repeat"></i>
            </div>
            <h3 class="poetsen-font">Easy Returns</h3>
            <p>Hassle-free returns within 30 days of purchase</p>
        </div>
    </div>

    <!-- Story Card -->
    <div class="row about-card">
        <div class="col-md-5">
            <img src="https://images.unsplash.com/photo-1556906781-9a412961c28c?w=800&q=80" 
                 alt="ReSole Story" 
                 class="about-card-img">
        </div>
        <div class="col-md-7 d-flex align-items-center">
            <div class="about-card-content">
                <p class="about-label">OUR STORY</p>
                <h2 class="poetsen-font">ReSole — New Steps, Same Soul</h2>
                <p>
                    ReSole is a great place to find quality shoes that reflect your unique style and personality. 
                    We believe that every step you take should be comfortable, confident, and stylish. Our carefully 
                    curated collection blends timeless designs with modern flair to fit any occasion.
                </p>
                <p>
                    Whether you're looking for everyday comfort or elegance for special occasions, ReSole is 
                    here to accompany you. Come by for your next step.
                </p>
            </div>
        </div>
    </div>

    <!-- Philosophy Card (Reversed) -->
    <div class="row about-card flex-md-row-reverse">
        <div class="col-md-5">
            <img src="https://images.unsplash.com/photo-1549298916-b41d501d3772?w=800&q=80" 
                 alt="Designed for daily life" 
                 class="about-card-img">
        </div>
        <div class="col-md-7 d-flex align-items-center">
            <div class="about-card-content">
                <p class="about-label">OUR PHILOSOPHY</p>
                <h2 class="poetsen-font">Designed for daily life</h2>
                <p>
                    We believe that great shoes aren't just accessories—they're an extension of who you are. 
                    That's why we focus on quality materials, expert craftsmanship, and 
                    products made to elevate your everyday life.
                </p>
                <p>
                    From the first stitch to the final polish, every pair in our collection is carefully selected, 
                    ensuring you get the perfect combination of style, comfort, and durability.
                </p>
            </div>
        </div>
    </div>
</div>
