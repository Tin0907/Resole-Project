@{
    ViewData["Title"] = "Welcome";
    Layout = "_WebLayout";
}

<!-- Hero Section -->
<div class="hero-section text-center py-5 mb-5" style="background: linear-gradient(135deg, rgba(212, 165, 116, 0.1) 0%, rgba(107, 165, 135, 0.1) 100%); border-radius: 1rem;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 text-lg-start mb-4 mb-lg-0">
                <h1 class="display-3 fw-bold mb-3" style="color: #4a3728 !important;">
                    Welcome to<br/>
                    <span style="color: #d4a574 !important;">ReSole Sneaker Store</span>
                </h1>
                <p class="lead mb-4" style="color: #6c757d !important;">
                    Discover the latest sneaker collection, combining performance and streetwear style.
                </p>
                <div class="d-grid gap-2 d-md-flex">
                    <a href="/ThucDon" class="btn btn-lg px-4" style="background: linear-gradient(135deg, #d4a574 0%, #c49361 100%); color: white; border: none;">
                        <i class="bi bi-bag me-2"></i>View Products
                    </a>
                    <a href="/Khachhang/Register" class="btn btn-success btn-lg px-4">
                        <i class="bi bi-person-plus me-2"></i>Register Now
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="text-center">
                    <i class="bi bi-basket3" style="font-size: 15rem; color: #d4a574; opacity: 0.8;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container mb-5">
    <div class="row text-center mb-4">
        <div class="col">
            <h2 class="fw-bold mb-3" style="color: #4a3728 !important;">Why Choose ReSole?</h2>
            <p class="text-muted">Reasons why customers love ReSole sneaker store</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Feature 1 -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-award-fill" style="font-size: 3rem; color: #d4a574;"></i>
                    </div>
                    <h5 class="fw-bold mb-3" style="color: #4a3728 !important;">Authentic Products</h5>
                    <p class="text-muted small">100% authentic shoes guarantee, reputable warranty.</p>
                </div>
            </div>
        </div>

        <!-- Feature 2 -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-lightning-charge-fill" style="font-size: 3rem; color: #6ba587;"></i>
                    </div>
                    <h5 class="fw-bold mb-3" style="color: #4a3728 !important;">Fast Delivery</h5>
                    <p class="text-muted small">Same-day processing, fast nationwide delivery.</p>
                </div>
            </div>
        </div>

        <!-- Feature 3 -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-star-fill" style="font-size: 3rem; color: #e8c158;"></i>
                    </div>
                    <h5 class="fw-bold mb-3" style="color: #4a3728 !important;">Diverse Collection</h5>
                    <p class="text-muted small">Many hot sneaker models from Nike, Adidas, New Balance...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="container mb-5">
    <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #4a3728 0%, #3d3026 100%);">
        <div class="card-body text-center py-5">
            <h3 class="fw-bold mb-3 text-white">Start your sneaker collection!</h3>
            <p class="text-white opacity-75 mb-4">Register to receive offers and the best shopping experience</p>
            <div class="d-grid gap-2 d-md-flex justify-content-center">
                <a href="/Khachhang/Register" class="btn btn-light btn-lg px-4">
                    <i class="bi bi-person-plus me-2"></i>Sign Up Free
                </a>
                <a href="/Khachhang/Login" class="btn btn-outline-light btn-lg px-4">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Login
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div class="container text-center mb-5">
    <div class="row g-4">
        <div class="col-md-3">
            <div class="p-4">
                <h2 class="display-4 fw-bold" style="color: #d4a574 !important;">500+</h2>
                <p class="text-muted">Shoe Models</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4">
                <h2 class="display-4 fw-bold" style="color: #6ba587 !important;">10K+</h2>
                <p class="text-muted">Happy Customers</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4">
                <h2 class="display-4 fw-bold" style="color: #e8c158 !important;">50+</h2>
                <p class="text-muted">Brands</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4">
                <h2 class="display-4 fw-bold" style="color: #d97777 !important;">24/7</h2>
                <p class="text-muted">Support</p>
            </div>
        </div>
    </div>
</div>
