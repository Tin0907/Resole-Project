@{
    ViewData["Title"] = "Contact Us";
    Layout = "~/Views/Shared/_WebLayout.cshtml";
}

<style>
    .contact-hero {
        padding: 60px 0 40px 0;
        text-align: center;
    }

    .contact-hero h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: #2d3748;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .contact-hero p {
        font-size: 1rem;
        color: #4a5568;
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.8;
        text-transform: uppercase;
        font-size: 0.9rem;
    }

    .contact-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin: 3rem 0;
    }

    .contact-card {
        background: white;
        border: 2px solid #e2e8f0;
        border-radius: 20px;
        padding: 3rem 2rem;
        text-align: center;
        transition: all 0.3s ease;
    }

    .contact-card:hover {
        border-color: #667eea;
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.15);
        transform: translateY(-5px);
    }

    .contact-icon {
        width: 70px;
        height: 70px;
        background: #f7fafc;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem;
        color: #2d3748;
        transition: all 0.3s ease;
    }

    .contact-card:hover .contact-icon {
        background: #667eea;
        color: white;
    }

    .contact-card h3 {
        font-size: 1.2rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .contact-card p {
        color: #718096;
        font-size: 0.95rem;
        margin: 0;
    }

    .location-section {
        margin-top: 4rem;
        padding-top: 3rem;
        border-top: 2px solid #e2e8f0;
    }

    .location-title {
        text-align: center;
        margin-bottom: 1rem;
    }

    .location-title h2 {
        font-size: 2rem;
        font-weight: 700;
        color: #2d3748;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 1rem;
    }

    .location-subtitle {
        font-size: 0.9rem;
        color: #4a5568;
        max-width: 800px;
        margin: 0 auto 2rem;
        line-height: 1.8;
        text-transform: uppercase;
    }

    .map-container {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }

    .map-container iframe {
        width: 100%;
        height: 450px;
        border: none;
    }

    .location-info {
        text-align: center;
        background: #f7fafc;
        padding: 2rem;
        border-radius: 15px;
        margin-top: 2rem;
    }

    .location-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
    }

    .location-info p {
        color: #4a5568;
        font-size: 1rem;
        margin: 0;
    }

    @@media (max-width: 768px) {
        .contact-hero h1 {
            font-size: 1.8rem;
        }

        .contact-cards {
            grid-template-columns: 1fr;
        }

        .map-container iframe {
            height: 300px;
        }

        .location-title h2 {
            font-size: 1.5rem;
        }
    }
</style>

<!-- Hero Section -->
<div class="contact-hero">
    <div class="container-fluid" style="width: 90%; max-width: 1600px; margin: 0 auto;">
        <h1 class="poetsen-font">Contact ReSole</h1>
        <p>
            We'd love to hear from you! Reach out if you have questions or need support.
        </p>
    </div>
</div>

<!-- Main Content -->
<div class="container-fluid" style="width: 90%; max-width: 1600px; margin: 0 auto;">
    <!-- Contact Cards -->
    <div class="contact-cards">
        <div class="contact-card">
            <div class="contact-icon">
                <i class="bi bi-envelope"></i>
            </div>
            <h3 class="poetsen-font">Email</h3>
            <p>info@resole.com</p>
        </div>

        <div class="contact-card">
            <div class="contact-icon">
                <i class="bi bi-telephone"></i>
            </div>
            <h3 class="poetsen-font">Phone Number</h3>
            <p>+84 123 456 789</p>
        </div>

        <div class="contact-card">
            <div class="contact-icon">
                <i class="bi bi-clock"></i>
            </div>
            <h3 class="poetsen-font">Opening Hours</h3>
            <p>Monday - Sunday<br>8:00 AM - 10:00 PM</p>
        </div>
    </div>

    <!-- Location Section -->
    <div class="location-section">
        <div class="location-title">
            <h2 class="poetsen-font">Find Our ReSole Shop</h2>
            <p class="location-subtitle">
                Discover premium footwear designed for comfort, style, and every step you take.<br>
                Drop by in comfort and immerse yourself in the world of ReSole.
            </p>
        </div>

        <!-- Google Map -->
        <div class="map-container">
            <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.324657355676!2d106.66408817485992!3d10.786817989363365!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752ed23c80767d%3A0x5a981a5efee9fd7d!2zVHLGsOG7nW5nIENhbyDEkeG6s25nIEZQVCBQb2x5dGVjaG5pYw!5e0!3m2!1svi!2s!4v1707900000000!5m2!1svi!2s"
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>

        <!-- Location Info -->
        <div class="location-info">
            <h3 class="poetsen-font">HO CHI MINH CITY</h3>
            <p>778 Nguyen Kiem, Ward 4, Phu Nhuan, Ho Chi Minh City, Vietnam</p>
        </div>
    </div>
</div>
