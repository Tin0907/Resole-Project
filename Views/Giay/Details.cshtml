@model ASM.Models.Giay
@{
    ViewData["Title"] = "Shoe Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0 fw-bold text-primary">
            <i class="bi bi-basket-fill me-2"></i>Shoe Details
        </h1>
        <p class="text-muted small">Detailed information about the shoe</p>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="row g-0">
        <div class="col-lg-5">
            @if (!string.IsNullOrEmpty(Model.Hinh))
            {
                <img src="~/images/Giay/@Model.Hinh" class="img-fluid w-100 h-100" style="object-fit: cover; border-radius: .75rem 0 0 .75rem;" alt="@Model.Ten" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center h-100 bg-light" style="border-radius: .75rem 0 0 .75rem; min-height: 280px;">
                    <i class="bi bi-image" style="font-size: 4rem; color: #ccc;"></i>
                </div>
            }
        </div>
        <div class="col-lg-7">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-3">@Model.Ten</h3>
                <p class="text-muted mb-3">@Model.MoTa</p>
                <div class="mb-3">
                    <span class="badge bg-success fs-6">@Model.Gia.ToString("N0") VNĐ</span>
                </div>
                <div class="mb-2">
                    <strong>Category: </strong><span class="badge bg-info">@Model.PhanLoai</span>
                </div>

                <div class="mb-2">
                    <strong>Quantity: </strong><span>@Model.Quantity</span>
                </div>

                <div class="mb-4">
                    <strong>Status: </strong>
                    @if (Model.Status == ASM.Models.ProductStatus.Locked)
                    {
                        <span class="badge bg-dark">Sản phẩm hiện đang bị khóa</span>
                    }
                    else if (Model.Quantity <= 0 || Model.Status == ASM.Models.ProductStatus.OutOfStock)
                    {
                        <span class="badge bg-danger">Hết hàng</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Còn hàng</span>
                    }
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this product?');">
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
