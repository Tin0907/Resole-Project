@{
    ViewData["Title"] = "Logout Successful";
    Layout = "_LoginLayout";
}

<!-- Logo/Brand (optional) -->
<div class="logo-brand">
    <img src="~/images/logo.png" alt="ReSole Logo" class="logo-brand-img" />
</div>

<div class="container">
    <div class="row">
        <div class="col-lg-5 col-md-6">
            <div class="card shadow-lg">
                <!-- Card Header -->
                <div class="card-header">
                    <i class="bi bi-box-arrow-right"></i>
                    <h3>Logout Successful</h3>
                    <p>You have been logged out of the system</p>
                </div>

                <!-- Card Body -->
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                    </div>
                    
                    <h5 class="text-white mb-3">Thank you for using the system!</h5>
                    <p class="text-white-50 mb-4">You have successfully logged out.</p>

                    <div class="d-grid gap-2">
                        <a asp-action="Login" class="btn btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Login Again
                        </a>
                        <a asp-controller="Home" asp-action="UserHome" class="btn btn-outline-light btn-lg">
                            <i class="bi bi-house me-2"></i>Return to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>