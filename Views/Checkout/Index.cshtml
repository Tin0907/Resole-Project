@{
    ViewData["Title"] = "Checkout";
    Layout = "_WebLayout";
    var khachHang = ViewBag.KhachHang as ASM.Models.KhachHang;
    var cartItems = ViewBag.CartItems as IEnumerable<dynamic>;
    var isBuyNow = (bool)(ViewBag.IsBuyNow ?? false);
}

<style>
    .checkout-page {
        background: #f8f9fa;
        min-height: calc(100vh - 200px);
        padding: 2rem 0;
    }

    .checkout-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .checkout-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 0.5rem;
    }

    .checkout-header p {
        color: #718096;
        font-size: 1.1rem;
    }

    .checkout-card {
        background: white;
        border: none;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label {
        font-weight: 600;
        color: #4a5568;
        margin-bottom: 0.5rem;
    }

    .form-control,
    .form-select {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.15);
    }

    .order-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
        border-bottom: 1px solid #e9ecef;
    }

    .order-item:last-child {
        border-bottom: none;
    }

    .item-info {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .item-image {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e9ecef;
    }

    .item-name {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.25rem;
    }

    .item-details {
        font-size: 0.9rem;
        color: #718096;
    }

    .item-price {
        font-weight: 700;
        color: #10b981;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        color: #4a5568;
    }

    .summary-total {
        display: flex;
        justify-content: space-between;
        padding-top: 1rem;
        margin-top: 1rem;
        border-top: 2px solid #e9ecef;
        font-size: 1.5rem;
        font-weight: 700;
        color: #2d3748;
    }

    .btn-place-order {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 1rem;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 10px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .btn-place-order:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
    }

    .security-badge {
        background: #f7fafc;
        padding: 1rem;
        border-radius: 10px;
        text-align: center;
        margin-top: 1rem;
    }

    .security-badge i {
        color: #10b981;
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .security-badge p {
        margin: 0;
        font-size: 0.9rem;
        color: #718096;
    }

    @@media (max-width: 768px) {
        .checkout-header h1 {
            font-size: 1.8rem;
        }

        .checkout-card {
            padding: 1.5rem;
        }
    }
</style>

<div class="checkout-page">
    <div class="container-fluid" style="width: 90%; max-width: 1600px; margin: 0 auto;">
        <!-- Header -->
        <div class="checkout-header">
            <h1><i class="bi bi-credit-card me-2"></i>Checkout</h1>
            <p>Complete your order</p>
        </div>

        <form asp-action="PlaceOrder" method="post" id="checkoutForm">
            @Html.AntiForgeryToken()
            <div class="row">
                <!-- Left Column: Customer Information -->
                <div class="col-lg-7">
                    <!-- Delivery Address -->
                    <div class="checkout-card">
                        <h5 class="section-title">
                            <i class="bi bi-geo-alt-fill"></i>Delivery Address
                        </h5>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="fullname" class="form-label">Full Name</label>
                                <input type="text" 
                                       id="fullname" 
                                       name="fullname" 
                                       class="form-control" 
                                       value="@khachHang?.Fullname"
                                       required />
                            </div>

                            <div class="col-md-6">
                                <label for="phone" class="form-label">Phone Number</label>
                                <input type="tel" 
                                       id="phone" 
                                       name="phoneNumber" 
                                       class="form-control" 
                                       value="@khachHang?.PhoneNumber"
                                       required />
                            </div>

                            <div class="col-12">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" 
                                       id="email" 
                                       name="email" 
                                       class="form-control" 
                                       value="@khachHang?.Email"
                                       required />
                            </div>

                            <div class="col-12">
                                <label for="address" class="form-label">Street Address</label>
                                <input type="text" 
                                       id="address" 
                                       name="deliveryAddress" 
                                       class="form-control" 
                                       placeholder="Enter your delivery address"
                                       required />
                            </div>

                            <div class="col-md-6">
                                <label for="city" class="form-label">Town/City</label>
                                <input type="text" 
                                       id="city" 
                                       name="city" 
                                       class="form-control" 
                                       placeholder="E.g. Ho Chi Minh"
                                       required />
                            </div>

                            <div class="col-md-6">
                                <label for="district" class="form-label">District</label>
                                <input type="text" 
                                       id="district" 
                                       name="district" 
                                       class="form-control" 
                                       placeholder="E.g. District 1"
                                       required />
                            </div>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="checkout-card">
                        <h5 class="section-title">
                            <i class="bi bi-credit-card-fill"></i>Payment Method
                        </h5>

                        <div class="form-check mb-3 p-3 border rounded" style="border-width: 2px !important;">
                            <input class="form-check-input" type="radio" name="paymentMethod" id="codPayment" value="cod" checked>
                            <label class="form-check-label w-100" for="codPayment">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>Cash on Delivery (COD)</strong>
                                        <p class="text-muted small mb-0">Pay when you receive the goods</p>
                                    </div>
                                    <i class="bi bi-cash-coin fs-2 text-success"></i>
                                </div>
                            </label>
                        </div>

                        <div class="form-check p-3 border rounded" style="border-width: 2px !important; opacity: 0.6;">
                            <input class="form-check-input" type="radio" name="paymentMethod" id="bankPayment" value="bank" disabled>
                            <label class="form-check-label w-100" for="bankPayment">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>Bank Transfer</strong>
                                        <p class="text-muted small mb-0">Coming soon</p>
                                    </div>
                                    <i class="bi bi-bank fs-2 text-primary"></i>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Order Notes -->
                    <div class="checkout-card">
                        <h5 class="section-title">
                            <i class="bi bi-chat-left-text-fill"></i>Order Notes
                        </h5>
                        <textarea name="notes" 
                                  class="form-control" 
                                  rows="4" 
                                  placeholder="Additional notes (optional)..."></textarea>
                    </div>
                </div>

                <!-- Right Column: Order Summary -->
                <div class="col-lg-5">
                    <div class="checkout-card">
                        <h5 class="section-title">
                            <i class="bi bi-receipt-cutoff"></i>Order Details
                        </h5>

                        @if (cartItems != null)
                        {
                            double total = 0;
                            foreach (var item in cartItems)
                            {
                                double thanhTien = (double)item.ThanhTien;
                                total += thanhTien;
                                <div class="order-item">
                                    <div class="item-info">
                                        <img src="~/images/Giay/@item.Hinh" alt="@item.TenGiay" class="item-image">
                                        <div>
                                            <div class="item-name">@item.TenGiay</div>
                                            <div class="item-details">
                                                Size: @item.Size | Qty: @item.SoLuong
                                            </div>
                                        </div>
                                    </div>
                                    <div class="item-price">
                                        @thanhTien.ToString("N0") VND
                                    </div>
                                </div>
                            }

                            <div class="mt-4">
                                <div class="summary-row">
                                    <span>Subtotal:</span>
                                    <span>@total.ToString("N0") VND</span>
                                </div>
                                
                                <div class="summary-row">
                                    <span>Shipping:</span>
                                    <span>Free</span>
                                </div>
                                
                                <div class="summary-total">
                                    <span>Total:</span>
                                    <span>@total.ToString("N0") VND</span>
                                </div>
                            </div>
                        }

                        <button type="submit" class="btn btn-place-order mt-3">
                            <i class="bi bi-check-circle me-2"></i>Place Order
                        </button>

                        <div class="security-badge">
                            <i class="bi bi-shield-check d-block"></i>
                            <p><strong>Your information is secured</strong></p>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
