@model IEnumerable<ASM.Models.NguoiDung>

@{
    ViewData["Title"] = "User Management";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="mb-0 fw-bold text-primary">
                <i class="bi bi-person-badge-fill me-2"></i>User Management
            </h1>
            <p class="text-muted small">Manage admin accounts</p>
        </div>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Add New User
        </a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12">
        <form method="get" asp-action="Index">
            <div class="input-group input-group-lg shadow-sm">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" 
                       name="searchTerm" 
                       value="@ViewData["CurrentFilter"]" 
                       class="form-control border-start-0 border-end-0 ps-0" 
                       placeholder="Search by name, email..." />
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search me-2"></i>Search
                </button>
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-2"></i>Clear
                    </a>
                }
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-light py-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold">
            <i class="bi bi-list-ul me-2"></i>User List
        </h6>
        <span class="badge bg-primary">Total: @Model.Count() users</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light border-bottom">
                    <tr>
                        <th class="fw-bold text-muted small text-uppercase">Username</th>
                        <th class="fw-bold text-muted small text-uppercase">Full Name</th>
                        <th class="fw-bold text-muted small text-uppercase">Email</th>
                        <th class="fw-bold text-muted small text-uppercase">Status</th>
                        <th class="fw-bold text-muted small text-uppercase text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td class="fw-bold">@item.User</td>
                                <td>@item.HoTen</td>
                                <td>@item.Email</td>
                                <td>
                                    @if (item.Locked)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Locked</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.NguoiDungID" class="btn btn-sm btn-outline-primary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Update" asp-route-id="@item.NguoiDungID" class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-danger" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#deleteModal-@item.NguoiDungID"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Delete Confirmation Modal -->
                            <div class="modal fade" id="deleteModal-@item.NguoiDungID" tabindex="-1" aria-labelledby="deleteModalLabel-@item.NguoiDungID" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title" id="deleteModalLabel-@item.NguoiDungID">
                                                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p class="mb-2">Are you sure you want to delete this user?</p>
                                            <p class="fw-bold text-danger mb-0">@item.HoTen</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                <i class="bi bi-x-circle me-2"></i>Cancel
                                            </button>
                                            <a asp-action="Delete" asp-route-id="@item.NguoiDungID" class="btn btn-danger">
                                                <i class="bi bi-trash me-2"></i>Delete
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-inbox display-4 d-block mb-3"></i>
                                <p class="mb-0">No users found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
