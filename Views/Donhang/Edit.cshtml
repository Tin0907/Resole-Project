@model ASM.Models.DonHang

@{
    ViewData["Title"] = "Edit Order";
    var currentStep = (int)Model.TrangThai;
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="mb-0 fw-bold text-primary">
            <i class="bi bi-pencil-square me-2"></i>Edit Order #@Model.Id
        </h1>
        <p class="text-muted small">Update order status step by step</p>
    </div>
</div>

<!-- Order Progress -->
<div class="card shadow-sm border-0 rounded-3 mb-4">
    <div class="card-body p-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-diagram-3 me-2"></i>Order Progress</h6>
        <div class="d-flex justify-content-between align-items-center position-relative px-3">
            <div class="progress position-absolute" style="height:4px;left:60px;right:60px;top:18px;z-index:0;">
                @{ int progressPercent = currentStep >= 4 ? 100 : (currentStep - 1) * 33; }
                <div class="progress-bar bg-success" style="width:@(progressPercent)%"></div>
            </div>
            @{
                var steps = new[] {
                    ("bi-clipboard-check", "Pending", 1),
                    ("bi-box-seam", "Packing", 2),
                    ("bi-truck", "Shipping", 3),
                    ("bi-check-circle", "Delivered", 4)
                };
            }
            @foreach (var (icon, label, step) in steps)
            {
                var done = currentStep >= step;
                var active = currentStep == step;
                <div class="text-center" style="z-index:1;min-width:70px;">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-1"
                         style="width:40px;height:40px;
                                background:@(done ? "#10b981" : "#e2e8f0");
                                color:@(done ? "white" : "#a0aec0");
                                border:@(active ? "3px solid #667eea" : "none");
                                font-size:1.1rem;">
                        <i class="bi @icon"></i>
                    </div>
                    <div class="small @(done ? "fw-bold text-dark" : "text-muted")">@label</div>
                </div>
            }
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <!-- Order Items -->
        <div class="card shadow-sm border-0 rounded-3 mb-4">
            <div class="card-header bg-light py-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-bag me-2"></i>Order Items</h6>
            </div>
            <div class="card-body p-0">
                @if (Model.DonhangChitiets != null && Model.DonhangChitiets.Any())
                {
                    @foreach (var item in Model.DonhangChitiets)
                    {
                        <div class="d-flex align-items-center gap-3 p-3 border-bottom">
                            <img src="~/images/Giay/@item.Giay?.Hinh"
                                 alt="@item.Giay?.Ten"
                                 style="width:70px;height:70px;object-fit:cover;border-radius:10px;border:1px solid #eee;" />
                            <div class="flex-grow-1">
                                <div class="fw-bold">@item.Giay?.Ten</div>
                                <small class="text-muted">Qty: @item.SoLuong · @item.GhiChu</small>
                            </div>
                            <div class="fw-bold text-success">@item.ThanhTien.ToString("N0") VND</div>
                        </div>
                    }
                }
                <div class="d-flex justify-content-between p-3 bg-light fw-bold">
                    <span>Total</span>
                    <span class="text-success fs-5">@Model.TongTien.ToString("N0") VND</span>
                </div>
            </div>
        </div>

        <!-- Customer Info -->
        <div class="card shadow-sm border-0 rounded-3 mb-4">
            <div class="card-header bg-light py-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-person me-2"></i>Customer Info</h6>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Name:</strong> @Model.KhachHang?.Fullname</p>
                <p class="mb-1"><strong>Email:</strong> @Model.KhachHang?.Email</p>
                <p class="mb-1"><strong>Phone:</strong> @Model.KhachHang?.PhoneNumber</p>
                <p class="mb-0"><strong>Order Date:</strong> @Model.NgayDatHang.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <!-- Status Update Form -->
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-light py-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-flag me-2"></i>Update Status</h6>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="KhachHangId" />
                    <input type="hidden" asp-for="NgayDatHang" />
                    <input type="hidden" asp-for="TongTien" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-4">
                        <label asp-for="TrangThai" class="form-label fw-bold">
                            <i class="bi bi-arrow-right-circle me-2"></i>Move to Status
                        </label>
                        <select asp-for="TrangThai"
                                asp-items="Html.GetEnumSelectList<ASM.Models.TrangThaiDonHang>()"
                                class="form-select form-select-lg">
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="GhiChu" class="form-label fw-bold">
                            <i class="bi bi-chat-left-text me-2"></i>Notes
                        </label>
                        <textarea asp-for="GhiChu" class="form-control" rows="4" placeholder="Enter notes..."></textarea>
                    </div>

                    <div class="d-grid gap-2">
                        @if (Model.TrangThai == ASM.Models.TrangThaiDonHang.ChoXacNhan)
                        {
                            <button type="submit" class="btn btn-warning btn-lg" onclick="document.getElementById('TrangThai').value='@((int)ASM.Models.TrangThaiDonHang.ChoLayHang)'">
                                <i class="bi bi-check2-circle me-2"></i>Confirm & Start Packing
                            </button>
                        }
                        else if (Model.TrangThai == ASM.Models.TrangThaiDonHang.ChoLayHang)
                        {
                            <button type="submit" class="btn btn-primary btn-lg" onclick="document.getElementById('TrangThai').value='@((int)ASM.Models.TrangThaiDonHang.ChoGiaoHang)'">
                                <i class="bi bi-truck me-2"></i>Hand Over to Delivery
                            </button>
                        }
                        else if (Model.TrangThai == ASM.Models.TrangThaiDonHang.ChoGiaoHang)
                        {
                            <button type="submit" class="btn btn-success btn-lg" onclick="document.getElementById('TrangThai').value='@((int)ASM.Models.TrangThaiDonHang.DaGiao)'">
                                <i class="bi bi-check-circle me-2"></i>Mark as Delivered
                            </button>
                        }

                        <button type="submit" class="btn btn-outline-primary">
                            <i class="bi bi-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Back to Orders
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
